# server/.gitignore
#
# Rules here apply relative to the server/ directory.
# Root-level .gitignore (c:\Proxima\.gitignore) already handles:
#   - node_modules, .env, dist, logs, OS files, editor configs
#
# Add server-specific rules below only if they are NOT already
# covered by the root .gitignore.

# Multer temp uploads — user-uploaded files must never be committed
uploads/temp/

# Compiled / transpiled output (if you ever add a build step)
dist/
build/

# PM2 ecosystem config with secrets (if used in future)
ecosystem.config.js
